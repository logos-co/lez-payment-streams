+std::string LEZCoreModule::send_generic_private_transaction_json(const std::string& payload_json) {
+    nlohmann::json doc = nlohmann::json::parse(payload_json, nullptr, false);
+    if (doc.is_discarded() || !doc.is_object()) {
+        return transferResultToJson(nullptr, "send_generic_private_transaction_json: invalid JSON payload");
+    }
+
+    if (!doc.contains("account_slots") || !doc["account_slots"].is_array()) {
+        return transferResultToJson(nullptr, "send_generic_private_transaction_json: missing account_slots");
+    }
+
+    std::vector<FfiAccountIdentity> identities_resolved;
+    identities_resolved.reserve(doc["account_slots"].size());
+
+    for (const auto& entry : doc["account_slots"]) {
+        if (!entry.is_object() || !entry.contains("account_id_hex") || !entry["account_id_hex"].is_string()) {
+            return transferResultToJson(nullptr, "send_generic_private_transaction_json: account_slots entries need account_id_hex");
+        }
+        if (!entry.contains("resolution") || !entry["resolution"].is_string()) {
+            return transferResultToJson(nullptr, "send_generic_private_transaction_json: account_slots entries need resolution");
+        }
+        FfiBytes32 id{};
+        if (!hexToBytes32(entry["account_id_hex"].get<std::string>(), &id)) {
+            return transferResultToJson(nullptr, "send_generic_private_transaction_json: invalid account_id_hex");
+        }
+        const std::string resolution = entry["resolution"].get<std::string>();
+        FfiAccountIdentity acc_identity{};
+        WalletFfiError resolve_error = INTERNAL_ERROR;
+        if (resolution == "private") {
+            resolve_error = wallet_ffi_resolve_private_account(walletHandle, id, &acc_identity);
+        } else if (resolution == "public_no_sign") {
+            resolve_error = wallet_ffi_resolve_public_account(id, false, &acc_identity);
+        } else if (resolution == "public_sign") {
+            resolve_error = wallet_ffi_resolve_public_account(id, true, &acc_identity);
+        } else {
+            return transferResultToJson(nullptr, "send_generic_private_transaction_json: unknown resolution");
+        }
+        if (resolve_error != SUCCESS) {
+            for (FfiAccountIdentity& prior : identities_resolved) {
+                wallet_ffi_free_account_identity(&prior);
+            }
+            return transferResultToJson(nullptr, std::string("send_generic_private_transaction_json: resolve failed ") + std::to_string(static_cast<int>(resolve_error)));
+        }
+        identities_resolved.push_back(acc_identity);
+    }
+
+    if (!doc.contains("instruction_hex") || !doc["instruction_hex"].is_string()) {
+        for (FfiAccountIdentity& prior : identities_resolved) {
+            wallet_ffi_free_account_identity(&prior);
+        }
+        return transferResultToJson(nullptr, "send_generic_private_transaction_json: missing instruction_hex");
+    }
+    std::vector<uint8_t> instruction_bytes;
+    if (!hexToBytes(doc["instruction_hex"].get<std::string>(), instruction_bytes)) {
+        for (FfiAccountIdentity& prior : identities_resolved) {
+            wallet_ffi_free_account_identity(&prior);
+        }
+        return transferResultToJson(nullptr, "send_generic_private_transaction_json: invalid instruction_hex");
+    }
+    if (instruction_bytes.empty() || (instruction_bytes.size() & 3) != 0) {
+        for (FfiAccountIdentity& prior : identities_resolved) {
+            wallet_ffi_free_account_identity(&prior);
+        }
+        return transferResultToJson(nullptr, "send_generic_private_transaction_json: instruction_hex length invalid");
+    }
+    std::vector<uint32_t> instruction;
+    instruction.reserve(instruction_bytes.size() / 4);
+    for (size_t i = 0; i < instruction_bytes.size(); i += 4) {
+        const uint32_t word = static_cast<uint32_t>(instruction_bytes[i])
+            | (static_cast<uint32_t>(instruction_bytes[i + 1]) << 8)
+            | (static_cast<uint32_t>(instruction_bytes[i + 2]) << 16)
+            | (static_cast<uint32_t>(instruction_bytes[i + 3]) << 24);
+        instruction.push_back(word);
+    }
+
+    if (!doc.contains("program_elf_hex") || !doc["program_elf_hex"].is_string()) {
+        for (FfiAccountIdentity& prior : identities_resolved) {
+            wallet_ffi_free_account_identity(&prior);
+        }
+        return transferResultToJson(nullptr, "send_generic_private_transaction_json: missing program_elf_hex");
+    }
+    std::vector<uint8_t> program_elf;
+    if (!hexToBytes(doc["program_elf_hex"].get<std::string>(), program_elf)) {
+        for (FfiAccountIdentity& prior : identities_resolved) {
+            wallet_ffi_free_account_identity(&prior);
+        }
+        return transferResultToJson(nullptr, "send_generic_private_transaction_json: invalid program_elf_hex");
+    }
+
+    std::vector<std::vector<uint8_t>> program_dependencies;
+    if (doc.contains("dependency_elf_hex_list") && doc["dependency_elf_hex_list"].is_array()) {
+        for (const auto& dep_entry : doc["dependency_elf_hex_list"]) {
+            if (!dep_entry.is_string()) {
+                for (FfiAccountIdentity& prior : identities_resolved) {
+                    wallet_ffi_free_account_identity(&prior);
+                }
+                return transferResultToJson(nullptr, "send_generic_private_transaction_json: dependency_elf_hex_list must be strings");
+            }
+            std::vector<uint8_t> dep_elf;
+            if (!hexToBytes(dep_entry.get<std::string>(), dep_elf)) {
+                for (FfiAccountIdentity& prior : identities_resolved) {
+                    wallet_ffi_free_account_identity(&prior);
+                }
+                return transferResultToJson(nullptr, "send_generic_private_transaction_json: invalid dependency elf hex");
+            }
+            program_dependencies.push_back(std::move(dep_elf));
+        }
+    }
+
+    return sendGenericPrivateTransactionResolved(
+        walletHandle,
+        identities_resolved,
+        instruction,
+        program_elf,
+        program_dependencies
+    );
+}
