+std::string LogosExecutionZoneWalletModule::send_generic_public_transaction_json(const std::string& payload_json) {
+    nlohmann::json doc;
+    try {
+        doc = nlohmann::json::parse(payload_json);
+    } catch (const nlohmann::json::exception& e) {
+        return transferResultToJson(nullptr, std::string("send_generic_public_transaction_json: invalid JSON: ") + e.what());
+    }
+    if (!doc.is_object()) {
+        return transferResultToJson(nullptr, std::string("send_generic_public_transaction_json: payload is not an object"));
+    }
+
+    std::vector<std::string> account_ids;
+    for (const auto& v : doc.value("account_ids", nlohmann::json::array())) {
+        account_ids.push_back(v.get<std::string>());
+    }
+    std::vector<bool> signing_requirements;
+    for (const auto& v : doc.value("signing_requirements", nlohmann::json::array())) {
+        signing_requirements.push_back(v.get<bool>());
+    }
+
+    const std::string instruction_hex = doc.value("instruction_hex", std::string());
+    std::vector<uint8_t> instruction_bytes;
+    if (!hexToBytes(instruction_hex, instruction_bytes)) {
+        return transferResultToJson(nullptr, std::string("send_generic_public_transaction_json: instruction_hex invalid"));
+    }
+    if (instruction_bytes.empty()) {
+        return transferResultToJson(nullptr, std::string("send_generic_public_transaction_json: instruction_hex empty"));
+    }
+
+    FfiInstructionWords words = wallet_ffi_serialization_helper(
+        instruction_bytes.data(),
+        static_cast<uintptr_t>(instruction_bytes.size()));
+    if (words.error != SUCCESS) {
+        const std::string msg = std::string("send_generic_public_transaction_json: serialization_helper error ") + std::to_string(static_cast<int>(words.error));
+        wallet_ffi_free_instruction_words(&words);
+        return transferResultToJson(nullptr, msg);
+    }
+    std::vector<uint32_t> instruction_words;
+    instruction_words.reserve(words.instruction_words_size);
+    for (uintptr_t i = 0; i < words.instruction_words_size; ++i) {
+        instruction_words.push_back(words.instruction_words[i]);
+    }
+    wallet_ffi_free_instruction_words(&words);
+
+    const std::string program_id_hex = doc.value("program_id_hex", std::string());
+
+    return send_generic_public_transaction(account_ids, signing_requirements, instruction_words, program_id_hex);
+}
