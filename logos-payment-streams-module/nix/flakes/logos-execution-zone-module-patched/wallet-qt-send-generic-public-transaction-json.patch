+// JSON-string entry point for send_generic_public_transaction. The codegen type
+// mapper does not support std::vector<uint32_t> (it degrades to an opaque "any"
+// that does not round-trip across the module boundary), so cross-module callers
+// pass a single JSON object here instead. instruction_hex is the little-endian
+// byte expansion of the risc0 instruction words (u32::to_le_bytes per word, the
+// same encoding produced by Program::serialize_instruction); it is regrouped
+// into u32 words before dispatch.
+std::string LEZCoreModule::send_generic_public_transaction_json(
+        const std::string& payload_json
+) {
+    nlohmann::json doc = nlohmann::json::parse(payload_json, nullptr, false);
+    if (doc.is_discarded() || !doc.is_object()) {
+        return genericTransactionResultToJson(nullptr, "send_generic_public_transaction_json: invalid JSON payload");
+    }
+
+    if (!doc.contains("account_ids") || !doc["account_ids"].is_array()) {
+        return genericTransactionResultToJson(nullptr, "send_generic_public_transaction_json: missing account_ids");
+    }
+    std::vector<std::string> account_ids;
+    for (const auto& entry : doc["account_ids"]) {
+        if (!entry.is_string()) {
+            return genericTransactionResultToJson(nullptr, "send_generic_public_transaction_json: account_ids must be hex strings");
+        }
+        account_ids.push_back(entry.get<std::string>());
+    }
+
+    if (!doc.contains("signing_requirements") || !doc["signing_requirements"].is_array()) {
+        return genericTransactionResultToJson(nullptr, "send_generic_public_transaction_json: missing signing_requirements");
+    }
+    std::vector<bool> signing_requirements;
+    for (const auto& entry : doc["signing_requirements"]) {
+        if (!entry.is_boolean()) {
+            return genericTransactionResultToJson(nullptr, "send_generic_public_transaction_json: signing_requirements must be booleans");
+        }
+        signing_requirements.push_back(entry.get<bool>());
+    }
+
+    if (account_ids.size() != signing_requirements.size()) {
+        return genericTransactionResultToJson(nullptr, "send_generic_public_transaction_json: account_ids/signing_requirements length mismatch");
+    }
+
+    if (!doc.contains("instruction_hex") || !doc["instruction_hex"].is_string()) {
+        return genericTransactionResultToJson(nullptr, "send_generic_public_transaction_json: missing instruction_hex");
+    }
+    std::vector<uint8_t> instruction_bytes;
+    if (!hexToBytes(doc["instruction_hex"].get<std::string>(), instruction_bytes)) {
+        return genericTransactionResultToJson(nullptr, "send_generic_public_transaction_json: invalid instruction_hex");
+    }
+    if (instruction_bytes.empty() || instruction_bytes.size() % 4 != 0) {
+        return genericTransactionResultToJson(nullptr, "send_generic_public_transaction_json: instruction_hex length must be a positive multiple of 4 bytes");
+    }
+    std::vector<uint32_t> instruction;
+    instruction.reserve(instruction_bytes.size() / 4);
+    for (size_t i = 0; i < instruction_bytes.size(); i += 4) {
+        const uint32_t word = static_cast<uint32_t>(instruction_bytes[i])
+            | (static_cast<uint32_t>(instruction_bytes[i + 1]) << 8)
+            | (static_cast<uint32_t>(instruction_bytes[i + 2]) << 16)
+            | (static_cast<uint32_t>(instruction_bytes[i + 3]) << 24);
+        instruction.push_back(word);
+    }
+
+    if (!doc.contains("program_id_hex") || !doc["program_id_hex"].is_string()) {
+        return genericTransactionResultToJson(nullptr, "send_generic_public_transaction_json: missing program_id_hex");
+    }
+    const std::string program_id_hex = doc["program_id_hex"].get<std::string>();
+
+    return send_generic_public_transaction(account_ids, signing_requirements, instruction, program_id_hex);
+}
