+/// Sign a 32-byte canonical payload digest with the nullifier secret key of an owned private account.
+#[no_mangle]
+pub unsafe extern "C" fn wallet_ffi_sign_private_payload(
+    handle: *mut WalletHandle,
+    account_id: *const FfiBytes32,
+    canonical_payload_digest: *const FfiBytes32,
+    out_signature: *mut FfiSignature64,
+) -> WalletFfiError {
+    let wrapper = match get_wallet(handle) {
+        Ok(w) => w,
+        Err(e) => return e,
+    };
+
+    if account_id.is_null() || canonical_payload_digest.is_null() || out_signature.is_null() {
+        print_error("Null pointer argument");
+        return WalletFfiError::NullPointer;
+    }
+
+    let wallet = match wrapper.core.lock() {
+        Ok(w) => w,
+        Err(e) => {
+            print_error(format!("Failed to lock wallet: {e}"));
+            return WalletFfiError::InternalError;
+        }
+    };
+
+    let account_id = AccountId::new(unsafe { (*account_id).data });
+
+    let Some(found) = wallet.storage().key_chain().private_account(account_id) else {
+        print_error("Private account not found in wallet");
+        return WalletFfiError::KeyNotFound;
+    };
+
+    let nsk = found.key_chain.private_key_holder.nullifier_secret_key;
+    let private_key = match PrivateKey::try_new(nsk) {
+        Ok(key) => key,
+        Err(_) => {
+            print_error("Invalid nullifier secret key for private account");
+            return WalletFfiError::InternalError;
+        }
+    };
+
+    let digest = unsafe { (*canonical_payload_digest).data };
+    let signature = Signature::new(&private_key, &digest);
+
+    unsafe {
+        (*out_signature).data = signature.value;
+    }
+
+    WalletFfiError::Success
+}
+
