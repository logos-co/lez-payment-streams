+std::string LogosExecutionZoneWalletModule::sign_public_payload(const std::string& account_id_hex, const std::string& digest_hex) {
+    FfiBytes32 id{};
+    if (!hexToBytes32(account_id_hex, &id)) {
+        fprintf(stderr, "sign_public_payload: invalid account_id_hex\n");
+        nlohmann::json err = nlohmann::json::object();
+        err["status"] = "error";
+        err["error"] = "invalid account_id_hex";
+        return err.dump();
+    }
+    FfiBytes32 digest{};
+    if (!hexToBytes32(digest_hex, &digest)) {
+        fprintf(stderr, "sign_public_payload: invalid digest_hex\n");
+        nlohmann::json err = nlohmann::json::object();
+        err["status"] = "error";
+        err["error"] = "invalid digest_hex";
+        return err.dump();
+    }
+    FfiSignature64 sig{};
+    const WalletFfiError error = wallet_ffi_sign_public_payload(walletHandle, &id, &digest, &sig);
+    if (error != SUCCESS) {
+        fprintf(stderr, "sign_public_payload: wallet FFI error %d\n", error);
+        nlohmann::json err = nlohmann::json::object();
+        err["status"] = "error";
+        err["error"] = std::string("wallet FFI error ") + std::to_string(static_cast<int>(error));
+        return err.dump();
+    }
+    nlohmann::json obj = nlohmann::json::object();
+    obj["status"] = "ok";
+    obj["result"] = bytesToHex(sig.data, 64);
+    return obj.dump();
+}
